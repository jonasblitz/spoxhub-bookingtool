# ─── Email-Agent: Beispiel-Konfiguration ──────────────────────────────────
# Diese Werte in deine .env übernehmen (NICHT committen — .env ist gitignored).

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# IMAP-Zugang (Posteingang lesen + Entwürfe schreiben)
IMAP_HOST=imap.deinprovider.de
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=service@spoxhub.de
IMAP_PASSWORD=app-passwort-hier

# Absender-Adresse für die Entwürfe (oft identisch mit IMAP_USER)
EMAIL_FROM=service@spoxhub.de

# Optional: Drafts-Ordner erzwingen (sonst Auto-Erkennung über \Drafts)
# IMAP_DRAFTS_FOLDER=Drafts

# Optional: günstigeres/anderes Modell (Standard: claude-opus-4-8)
# Für sehr hohes Mail-Volumen z.B. claude-haiku-4-5 zur Klassifikation.
# EMAIL_AGENT_MODEL=claude-opus-4-8
