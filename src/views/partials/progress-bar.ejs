<!-- Progress Bar + Back Button -->
<div class="progress-shell">
  <div class="progress-shell__row">
    <button type="button" id="btn-back" class="progress-back" aria-label="Zurück" onclick="flowBack()">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <span class="progress-shell__percent" id="progress-percent">0 %</span>
  </div>
  <div class="progress-shell__track">
    <div class="progress-shell__bar" id="progress-bar" style="width:0%"></div>
  </div>
</div>
