<section class="screen-panel is-hidden" data-screen="bike-photo">
  <h2 class="screen-panel__question">Foto von deinem Rad</h2>
  <p class="screen-panel__hint">Wenn du hast, hilft uns ein Foto, das Modell genau zu identifizieren. <span class="text-text-muted">(optional)</span></p>

  <div class="form-group">
    <div id="bike-upload-dropzone" class="upload-dropzone" onclick="document.getElementById('bike-file-input').click()">
      <input type="file" id="bike-file-input" class="hidden"
             accept="image/*" onchange="handleBikePhoto(this.files)">
      <div class="upload-dropzone__content">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-text-muted">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        <span class="text-sm text-text-muted">Klicken oder Foto hierher ziehen</span>
      </div>
    </div>
    <div id="bike-photo-preview" class="mt-3 hidden"></div>
  </div>

  <div class="screen-footer">
    <div class="screen-footer__inner">
      <button type="button" class="btn-cta" onclick="flowNext()">Weiter</button>
      <a class="screen-skip" onclick="flowSkip()">Überspringen</a>
    </div>
  </div>
</section>
