<section class="screen-panel is-hidden" data-screen="slot-select">
  <h2 class="screen-panel__question">Wann passt es dir?</h2>
  <p class="screen-panel__hint">Wähle einen freien Termin.</p>

  <!-- Monat-Navigation -->
  <div class="sidebar-card !p-4">
    <div class="flex items-center justify-between mb-4">
      <button type="button" class="btn-icon !w-8 !h-8 !min-h-0" onclick="changeMonth(-1)" aria-label="Vorheriger Monat">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <span id="month-label" class="text-white font-body font-bold text-lg"></span>
      <button type="button" class="btn-icon !w-8 !h-8 !min-h-0" onclick="changeMonth(1)" aria-label="Nächster Monat">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    <!-- Wochentage -->
    <div class="grid grid-cols-7 gap-1 mb-2">
      <span class="cal-header">Mo</span>
      <span class="cal-header">Di</span>
      <span class="cal-header">Mi</span>
      <span class="cal-header">Do</span>
      <span class="cal-header">Fr</span>
      <span class="cal-header">Sa</span>
      <span class="cal-header">So</span>
    </div>

    <div id="month-grid" class="grid grid-cols-7 gap-1"></div>
  </div>

  <!-- Slots -->
  <div class="sidebar-card !p-4 mt-4">
    <h3 class="text-white font-body font-bold text-base mb-3">
      <span id="slots-date-label" class="text-neon-lime">Datum wählen</span>
    </h3>

    <div id="slots-container">
      <div id="slots-loading" class="hidden text-center py-6">
        <div class="inline-block w-8 h-8 border-2 border-neon-lime border-t-transparent rounded-full animate-spin"></div>
        <p class="text-text-muted mt-3 text-sm">Zeiten werden geladen...</p>
      </div>
      <div id="slots-grid" class="grid grid-cols-2 gap-2 max-h-[300px] overflow-y-auto pr-1"></div>
      <p id="no-slots" class="text-text-muted text-sm italic text-center py-4 hidden">
        Keine Termine an diesem Tag verfügbar.
      </p>
      <p id="slots-placeholder" class="text-text-muted text-sm italic text-center py-6">
        Wähle oben ein Datum.
      </p>
    </div>
  </div>

  <div class="screen-footer">
    <div class="screen-footer__inner">
      <button type="button" id="btn-slot-next" class="btn-cta" disabled onclick="confirmSlotAndAdvance()">Weiter</button>
    </div>
  </div>
</section>
