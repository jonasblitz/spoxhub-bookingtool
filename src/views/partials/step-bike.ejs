<section class="step-panel is-hidden" data-step="3">
  <div class="space-y-10 stagger-in">

    <!-- Fahrrad anlegen -->
    <div class="form-section">
      <h2 class="section-heading">Dein Fahrrad</h2>
      <div class="info-badge mb-6">
        <span class="info-badge__check">&#10003;</span>
        <span>Hilft uns, deinen Service optimal vorzubereiten!</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-5">
        <div class="form-group relative">
          <label class="form-label !text-base !font-body !text-text-secondary" for="b-marke">Marke *</label>
          <input type="text" id="b-marke" class="form-input" required autocomplete="off"
                 placeholder="Marke suchen..."
                 data-field="bike.marke" onblur="onBrandBlur(this)" oninput="onBrandInput(this)">
          <div id="brand-dropdown" class="brand-dropdown hidden"></div>
          <div id="brand-status" class="hidden mt-2"></div>
          <span class="form-error hidden" role="alert"></span>
        </div>

        <div class="form-group">
          <label class="form-label !text-base !font-body !text-text-secondary" for="b-modell">Modell</label>
          <input type="text" id="b-modell" class="form-input"
                 placeholder="z.B. Endurace CF 7"
                 data-field="bike.modell" oninput="updateCustomerField(this)">
        </div>

        <div class="form-group sm:col-span-2">
          <label class="form-label !text-base !font-body !text-text-secondary" for="b-rahmen">Rahmennummer (optional)</label>
          <input type="text" id="b-rahmen" class="form-input"
                 data-field="bike.rahmennummer" oninput="updateCustomerField(this)">
        </div>
      </div>

      <!-- Leasing -->
      <div class="mt-6">
        <label class="checkbox-row">
          <input type="checkbox" id="b-is-leasing" class="checkbox-input" onchange="toggleBikeSection('leasing', this.checked)">
          <span class="checkbox-label">Ist ein Leasingrad</span>
        </label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 mt-3 hidden" id="leasing-fields">
          <div class="form-group">
            <label class="form-label !text-base !font-body !text-text-secondary" for="b-leasing-company">Leasinggesellschaft</label>
            <input type="text" id="b-leasing-company" class="form-input"
                   placeholder="z.B. JobRad, Lease a Bike"
                   data-field="bike.leasing" oninput="updateCustomerField(this)">
          </div>
          <div class="form-group">
            <label class="form-label !text-base !font-body !text-text-secondary" for="b-leasing-nr">Vertragsnummer</label>
            <input type="text" id="b-leasing-nr" class="form-input"
                   placeholder="Vertragsnummer"
                   data-field="bike.leasingNr" oninput="updateCustomerField(this)">
          </div>
        </div>
      </div>

      <!-- Versicherung -->
      <div class="mt-6">
        <label class="checkbox-row">
          <input type="checkbox" id="b-is-versichert" class="checkbox-input" onchange="toggleBikeSection('versicherung', this.checked)">
          <span class="checkbox-label">Ist versichert</span>
        </label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 mt-3 hidden" id="versicherung-fields">
          <div class="form-group">
            <label class="form-label !text-base !font-body !text-text-secondary" for="b-versicherung-company">Versicherung</label>
            <input type="text" id="b-versicherung-company" class="form-input"
                   placeholder="z.B. Wertgarantie, Enra"
                   data-field="bike.versicherung" oninput="updateCustomerField(this)">
          </div>
          <div class="form-group">
            <label class="form-label !text-base !font-body !text-text-secondary" for="b-versicherung-nr">Vertragsnummer</label>
            <input type="text" id="b-versicherung-nr" class="form-input"
                   placeholder="Vertragsnummer"
                   data-field="bike.versicherungNr" oninput="updateCustomerField(this)">
          </div>
        </div>
      </div>
    </div>

    <!-- Foto vom Fahrrad -->
    <div class="form-section">
      <div class="form-group">
        <label class="form-label !text-base !font-body !text-text-secondary">
          Foto von deinem Fahrrad <span class="text-text-muted">(optional)</span>
        </label>
        <p class="text-sm text-text-muted mb-3">Wenn du hast, hilft uns ein Bild von deinem ganzen Fahrrad weiter, das Modell zu identifizieren.</p>
        <div id="bike-upload-dropzone" class="upload-dropzone" onclick="document.getElementById('bike-file-input').click()">
          <input type="file" id="bike-file-input" class="hidden"
                 accept="image/*" onchange="handleBikePhoto(this.files)">
          <div class="upload-dropzone__content">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-text-muted">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span class="text-sm text-text-muted">Klicken oder Foto hierher ziehen</span>
          </div>
        </div>
        <div id="bike-photo-preview" class="mt-3 hidden"></div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="flex justify-between">
      <button type="button" class="btn-cta !w-auto !bg-purple-700 !text-white" onclick="goToStep(2)">
        Zurück
      </button>
      <button type="button" class="btn-cta !w-auto" id="btn-step3-next" disabled onclick="goToStep(4)">
        Weiter zu deinen Daten
      </button>
    </div>

  </div>
</section>
