<section class="step-panel" data-step="1">
  <div class="space-y-10 stagger-in">

    <!-- Fahrzeugtyp -->
    <div class="form-section">
      <h2 class="section-heading">Was für ein Rad?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <button type="button" class="service-card" data-vehicle="ebike" onclick="selectVehicle(this)">
          <span class="service-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/>
              <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
              <path d="M6.5 17.5h0" stroke-width="0"/><path d="M5 3l1 2"/></svg>
          </span>
          <span class="service-card__label">E-Bike</span>
        </button>
        <button type="button" class="service-card" data-vehicle="cargobike" onclick="selectVehicle(this)">
          <span class="service-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/>
              <path d="M5.5 17.5H3V7h4l5 4H9v6.5"/><path d="M12 11h5l1.5 6.5"/>
            </svg>
          </span>
          <span class="service-card__label">Cargobike</span>
        </button>
      </div>
    </div>

    <!-- Standort-Auswahl -->
    <div class="form-section">
      <h2 class="section-heading">Wo sollen wir hinkommen?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <button type="button" class="location-card" data-location="mobil" onclick="selectLocation(this)">
          <span class="location-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </span>
          <span class="location-card__label">Zu dir nach Hause</span>
          <span class="location-card__sub">Wir kommen mobil zu dir</span>
        </button>
        <button type="button" class="location-card" data-location="anderer_ort" onclick="selectLocation(this)">
          <span class="location-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span class="location-card__label">Anderer Ort</span>
          <span class="location-card__sub">Wir kommen zu deiner Adresse</span>
        </button>
        <button type="button" class="location-card" data-location="werkstatt" onclick="selectLocation(this)">
          <span class="location-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </span>
          <span class="location-card__label">In der Werkstatt</span>
          <span class="location-card__sub">Keine Anfahrtskosten</span>
        </button>
      </div>
    </div>

    <!-- Adresseingabe (nur bei mobil/anderer_ort) -->
    <div id="address-section" class="form-section hidden">
      <label class="form-label" id="address-label">Deine Adresse</label>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-3">
        <div class="form-group sm:col-span-2">
          <label class="form-label !text-base !font-body !text-text-secondary" for="address-street">Straße & Hausnummer *</label>
          <input type="text" id="address-street" class="form-input" required
                 placeholder="z.B. Mönckebergstraße 1">
          <span class="form-error hidden" role="alert"></span>
        </div>
        <div class="form-group">
          <label class="form-label !text-base !font-body !text-text-secondary" for="address-plz">PLZ *</label>
          <input type="text" id="address-plz" class="form-input" required inputmode="numeric"
                 placeholder="z.B. 20095" maxlength="5" oninput="onPlzInput(this)">
          <span class="form-error hidden" role="alert"></span>
        </div>
        <div class="form-group relative">
          <label class="form-label !text-base !font-body !text-text-secondary" for="address-city">Ort *</label>
          <input type="text" id="address-city" class="form-input" required
                 placeholder="Wird automatisch geladen...">
          <span id="plz-loading" class="absolute right-1 top-9 hidden">
            <span class="inline-block w-4 h-4 border-2 border-neon-lime border-t-transparent rounded-full animate-spin"></span>
          </span>
          <span class="form-error hidden" role="alert"></span>
        </div>
      </div>
      <div class="mt-4">
        <button type="button" id="btn-check-address" class="btn-cta !w-auto !px-6" onclick="checkAddress()">
          Verfügbarkeit prüfen
        </button>
      </div>
      <div id="geo-feedback" class="mt-3 hidden" role="status" aria-live="polite"></div>
    </div>

    <!-- Out-of-area Hinweis -->
    <div id="out-of-area" class="hidden">
      <div class="bg-purple-800 border border-state-warning rounded-xl p-6 space-y-4">
        <p class="text-white">
          <span class="text-state-warning font-bold">Leider noch nicht in unserem Einsatzgebiet.</span><br>
          Du kannst aber einen Termin in unserer Werkstatt buchen.
        </p>
        <p class="text-text-secondary text-sm">
          Wenn du als Erstes erfahren willst, wann wir auch zu dir kommen, trag dich in unseren Newsletter ein:
        </p>
        <div class="flex gap-3">
          <input type="email" id="newsletter-email" class="form-input flex-1" placeholder="Deine E-Mail-Adresse">
          <button type="button" class="btn-cta !w-auto !px-6 !text-sm" onclick="subscribeNewsletter()">Eintragen</button>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="flex justify-end">
      <button type="button" class="btn-cta !w-auto" id="btn-step1-next" disabled onclick="goToStep(2)">
        Weiter zu den Leistungen
      </button>
    </div>

  </div>
</section>
